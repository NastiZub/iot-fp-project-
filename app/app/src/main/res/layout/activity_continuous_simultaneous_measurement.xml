<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F7F4FB">

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

            <ImageButton
                    android:id="@+id/backButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back"
                    android:elevation="10dp"
                    android:clickable="true"
                    android:focusable="true" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitorización simultánea"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#2B2233"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccione varios sensores. Cada sensor tendrá su propio gráfico."
                    android:textSize="15sp"
                    android:textColor="#6F6478"
                    android:layout_marginBottom="20dp" />

            <EditText
                    android:id="@+id/intervalEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Intervalo entre mediciones (segundos)"
                    android:inputType="number"
                    android:layout_marginBottom="16dp" />

            <CheckBox
                    android:id="@+id/temperatureCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BME280 Temp — Temperatura (°C)" />

            <CheckBox
                    android:id="@+id/humidityCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BME280 Humidity — Humedad (%)" />

            <CheckBox
                    android:id="@+id/pressureCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BME280 Pressure — Presión (hPa)" />

            <CheckBox
                    android:id="@+id/lightCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BH1750 Light — Luz (lux)" />

            <CheckBox
                    android:id="@+id/distanceCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VL53L1X Distance — Distancia (cm)" />

            <CheckBox
                    android:id="@+id/currentCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INA219 Current — Corriente (A)" />

            <CheckBox
                    android:id="@+id/voltageCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INA219 Voltage — Voltaje (V)" />

            <CheckBox
                    android:id="@+id/powerCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INA219 Power — Potencia (W)" />

            <CheckBox
                    android:id="@+id/gasCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MQ135 Gas Sensor — Gas (ppm)" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                <Button
                        android:id="@+id/startButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Iniciar" />

                <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                <Button
                        android:id="@+id/stopButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Detener"
                        android:backgroundTint="#EF9A9A"
                        android:textColor="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="18dp">

                <TextView
                        android:id="@+id/savePdfButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guardar PDF"
                        android:textColor="#4A235A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textColor="#6E6E73"
                        android:textSize="16sp" />

                <TextView
                        android:id="@+id/saveCsvButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guardar CSV"
                        android:textColor="#4A235A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/chartsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:scrollbars="none">

                <TableLayout
                        android:id="@+id/measurementsTable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:padding="16dp"
                        android:stretchColumns="0,1,2" />

            </HorizontalScrollView>



        </LinearLayout>
    </ScrollView>

    <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp">

        <include layout="@layout/bottom_navigation" />

    </FrameLayout>

</LinearLayout>