<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F2F2F7">

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="26dp"
                android:paddingBottom="24dp">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panel principal"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:textColor="#111111" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccione el modo de trabajo del sistema IoT"
                    android:textSize="16sp"
                    android:fontFamily="sans"
                    android:textColor="#6E6E73"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="30dp" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medición instantánea"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:textColor="#111111"
                    android:layout_marginBottom="12dp" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipToPadding="false">

                <LinearLayout
                        android:id="@+id/instantIndividualButton"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">

                    <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_instant" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Individual"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="sans"
                            android:textColor="#111111"
                            android:layout_marginTop="16dp" />
                </LinearLayout>

                <Space
                        android:layout_width="16dp"
                        android:layout_height="1dp" />

                <LinearLayout
                        android:id="@+id/instantSimultaneousButton"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">

                    <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_stopwatch" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Simultánea"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="sans"
                            android:textColor="#111111"
                            android:layout_marginTop="16dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medición continua"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:textColor="#111111"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="12dp" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <LinearLayout
                        android:id="@+id/continuousIndividualButton"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">

                    <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_line_chart" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Individual"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="sans"
                            android:textColor="#111111"
                            android:layout_marginTop="16dp" />
                </LinearLayout>

                <Space
                        android:layout_width="16dp"
                        android:layout_height="1dp" />

                <LinearLayout
                        android:id="@+id/continuousSimultaneousButton"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">

                    <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_monitor" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Simultánea"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="sans"
                            android:textColor="#111111"
                            android:layout_marginTop="16dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Otros"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:textColor="#111111"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="12dp" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <LinearLayout
                        android:id="@+id/rfidRegisterButton"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">

                    <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_rfid" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registro RFID"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans"
                            android:textColor="#111111"
                            android:layout_marginTop="16dp" />
                </LinearLayout>

                <Space
                        android:layout_width="16dp"
                        android:layout_height="1dp" />

                <LinearLayout
                        android:id="@+id/artificialVisionButton"
                        android:layout_width="0dp"
                        android:layout_height="158dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_home_card"
                        android:elevation="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">

                    <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_camera" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Visión artificial"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans"
                            android:textColor="#111111"
                            android:layout_marginTop="16dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                    android:id="@+id/usersButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuarios"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:visibility="gone"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="34dp"
                    android:clickable="true"
                    android:focusable="true" />

            <TextView
                    android:id="@+id/logoutButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cerrar sesión"
                    android:textColor="#D32F2F"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp"
                    android:clickable="true"
                    android:focusable="true" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp">

        <include layout="@layout/bottom_navigation" />

    </FrameLayout>

</LinearLayout>