<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2F2F7">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

        <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/ic_iot"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="8dp" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_home_card"
                android:elevation="8dp"
                android:padding="22dp">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio de sesión"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:textColor="#111111"
                    android:layout_marginBottom="18dp" />

            <EditText
                    android:id="@+id/usernameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Usuario" />

            <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:layout_marginTop="12dp" />

            <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Entrar"
                    android:layout_marginTop="22dp" />

        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_home_card"
                android:elevation="8dp"
                android:padding="18dp"
                android:layout_marginTop="18dp">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acceso RFID"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans"
                    android:textColor="#111111"
                    android:layout_marginBottom="12dp" />

            <EditText
                    android:id="@+id/rfidUidEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="UID RFID" />

            <Button
                    android:id="@+id/rfidButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Acceder con RFID"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="#9E9E9E"
                    android:textColor="#FFFFFF" />

        </LinearLayout>

        <TextView
                android:id="@+id/goToRegisterButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear cuenta"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                android:clickable="true"
                android:focusable="true" />

        <TextView
                android:id="@+id/messageTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#4A235A"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="20dp" />

    </LinearLayout>

</ScrollView>